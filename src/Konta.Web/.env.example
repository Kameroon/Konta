# Configuration de l'application Konta ERP
# Copier ce fichier en .env.local et ajuster les valeurs

# Titre de l'application
VITE_APP_TITLE=Konta ERP

# URL de base de l'API Gateway
VITE_API_BASE_URL=http://localhost:5000

# URLs des microservices (si accès direct nécessaire)
VITE_IDENTITY_API_URL=http://localhost:5001
VITE_TENANT_API_URL=http://localhost:5002
VITE_FINANCE_API_URL=http://localhost:5003
VITE_BILLING_API_URL=http://localhost:5004
VITE_OCR_API_URL=http://localhost:5005
VITE_REPORTING_API_URL=http://localhost:5006

# Mode de développement
VITE_DEV_MODE=true

# Activer les logs de debug
VITE_DEBUG=true
