{
    "Routes": [
        {
            "DownstreamPathTemplate": "/api/identity/{everything}",
            "DownstreamScheme": "https",
            "DownstreamHostAndPorts": [
                {
                    "Host": "localhost",
                    "Port": 5001
                }
            ],
            "UpstreamPathTemplate": "/gateway/identity/{everything}",
            "UpstreamHttpMethod": [
                "Get",
                "Post",
                "Put",
                "Delete",
                "Patch"
            ],
            "AuthenticationOptions": {
                "AuthenticationProviderKey": "Bearer",
                "AllowedScopes": []
            }
        }
    ]
}